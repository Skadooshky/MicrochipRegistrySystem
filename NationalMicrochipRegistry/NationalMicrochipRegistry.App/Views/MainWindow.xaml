<Window x:Class="NationalMicrochipRegistry.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NationalMicrochipRegistry.App.Views"
        Title="National Microchip Registry"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <TabControl x:Name="MainTabControl">
            <!-- =====================
                 1) Animals Tab (always visible)
                 ===================== -->
            <TabItem Header="Animals">
                <views:AnimalView/>
            </TabItem>

            <!-- =====================
                 2) Clinics Tab (always visible)
                 ===================== -->
            <TabItem Header="Clinics">
                <views:ClinicView/>
            </TabItem>

            <!-- =====================
                 3) Microchips Tab (hidden for Role=User)
                 ===================== -->
            <TabItem x:Name="MicrochipsTab" Header="Microchips">
                <views:MicrochipView/>
            </TabItem>

            <!-- =====================
                 4) Users Tab (hidden for Role=User)
                 ===================== -->
            <TabItem x:Name="UsersTab" Header="Users">
                <views:UserView/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
